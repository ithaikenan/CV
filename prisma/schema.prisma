// Playoff Monkey schema
// Use SQLite for local dev; set DATABASE_URL to Postgres for prod (update provider).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Neon (via Vercel marketplace) injects DATABASE_URL (pooled)
  // and DATABASE_URL_UNPOOLED (direct, for migrations).
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// --- Auth.js / NextAuth ---------------------------------------------------

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isMonkey      Boolean      @default(false)
  createdAt     DateTime     @default(now())

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  guesses     Guess[]
  leaguesOwned League[]     @relation("LeagueOwner")
  feedback    Feedback[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App ------------------------------------------------------------------

model League {
  id              String        @id @default(cuid())
  name            String
  isGlobal        Boolean       @default(false)
  inviteCode      String        @unique @default(cuid())
  ownerId         String?
  owner           User?         @relation("LeagueOwner", fields: [ownerId], references: [id])
  rules           String?       // Admin-set "house rules" (markdown-lite, free text).
  rulesUpdatedAt  DateTime?
  createdAt       DateTime      @default(now())
  memberships     Membership[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  leagueId  String
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([leagueId])
}

// Round: 1..4 (first, second, conference finals, nba finals)
model Game {
  id         String   @id                // external id from provider (e.g. ESPN event id)
  round      Int                         // 1..4
  seriesId   String?                     // optional series grouping
  homeTeam   String
  awayTeam   String
  homeSeed   Int?
  awaySeed   Int?
  tipoffAt   DateTime
  status     String   @default("scheduled") // scheduled | live | final
  homeScore  Int?                          // live or final regulation score
  awayScore  Int?                          // live or final regulation score
  // regulation-only scores (excluding OT), used for scoring once status=final
  homeRegScore Int?
  awayRegScore Int?
  period     Int?                          // current period (1..4 reg, 5+ OT)
  clock      String?                       // display clock, e.g., "4:12"
  updatedAt  DateTime @updatedAt

  guesses Guess[]

  @@index([tipoffAt])
  @@index([status])
}

// User-submitted bug reports / inquiries. Admins triage at /admin/feedback.
model Feedback {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  category   String    @default("other")   // bug | inquiry | feature | other
  subject    String?
  message    String
  status     String    @default("open")    // open | resolved
  adminNote  String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status, createdAt])
}

model Guess {
  id         String   @id @default(cuid())
  userId     String
  gameId     String
  homeScore  Int
  awayScore  Int
  // locked snapshot to prevent late edits even if tipoffAt changes after lock
  lockedAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
}

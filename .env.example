# --- NextAuth ---
# Long random string (openssl rand -base64 32)
AUTH_SECRET=replace-me
# Public base URL in production (e.g., https://playoffmonkey.com)
AUTH_URL=http://localhost:3000
# Trust the AUTH_URL host behind proxies (Vercel/Cloud Run/etc)
AUTH_TRUST_HOST=true

# --- OAuth providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- Database ---
# Local dev: SQLite file
DATABASE_URL="file:./dev.db"
# Prod (Postgres example):
# DATABASE_URL="postgresql://user:pass@host:5432/playoffmonkey?schema=public"

# --- NBA feed ---
# espn (default, free) | balldontlie (requires BDL_API_KEY)
NBA_PROVIDER=espn
BDL_API_KEY=

# --- Cron protection ---
CRON_SECRET=replace-me

# --- NextAuth ---
# Long random string (openssl rand -base64 32)
AUTH_SECRET=replace-me
# Public base URL in production (e.g., https://playoffmonkey.com)
AUTH_URL=https://playoffmonkey.com
# Required behind Vercel/proxies
AUTH_TRUST_HOST=true

# --- OAuth providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — leave empty until you add Facebook Login
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- Database (Vercel Postgres / Neon) ---
# Vercel sets these automatically when you attach the Postgres integration.
# For local dev, paste the values from your Neon dashboard.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# --- NBA feed ---
# espn (default, free) | balldontlie (requires BDL_API_KEY)
NBA_PROVIDER=espn
BDL_API_KEY=

# --- Cron protection ---
# Required by /api/cron/sync — keep secret.
CRON_SECRET=replace-me

# --- Admin ---
# Comma-separated list of emails allowed at /admin.
ADMIN_EMAILS=you@example.com
